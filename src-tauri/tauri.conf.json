{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "GradeScope",
  "version": "1.0.0",
  "identifier": "com.zhangyiming666.gradescope",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://127.0.0.1:5173",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "GradeScope",
        "width": 1280,
        "height": 832,
        "minWidth": 960,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg", "nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "Education",
    "copyright": "Copyright © 2026 GradeScope",
    "shortDescription": "GradeScope - 学业成绩管理",
    "longDescription": "GradeScope 学业成绩管理工具，本地存储，离线可用。"
  }
}
